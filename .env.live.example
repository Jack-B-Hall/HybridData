# Reference "live" deployment config: real embeddings + a real answer model.
#
# The reference stack is intentionally WESTERN-ORIGIN (Google / Nomic AI / US
# sentence-transformers / Anthropic) so it is deployable in restricted and
# sovereign environments with model-provenance requirements.
#
# Copy to `.env.live` and edit the hosts/models, then use the `make *-live`
# targets (which source this file).
#
# Embeddings: nomic-embed-text (Nomic AI, US) via a local Ollama server. The
# dimension (768) is discovered from the server automatically.
HDE_EMBEDDER=ollama
HDE_OLLAMA_EMBED_HOST=http://127.0.0.1:11434
HDE_EMBED_MODEL=nomic-embed-text

# Answer model: gemma4:26b-a4b-it-qat (Google) — a fast ~15 GB mixture-of-experts
# variant that fits a single 16-32 GB GPU. Point HDE_OLLAMA_LLM_HOST at whichever
# host serves it. Reasoning "thinking" is off by default for latency; generation
# is capped and the context window trimmed to keep answers snappy.
HDE_LLM_BACKEND=ollama
HDE_OLLAMA_LLM_HOST=http://127.0.0.1:11434
HDE_LLM_MODEL=gemma4:26b-a4b-it-qat
HDE_LLM_TIMEOUT_S=600
HDE_LLM_THINK=0
HDE_LLM_NUM_PREDICT=1000
HDE_LLM_NUM_CTX=8192

# Keep the live store separate from the offline demo store.
HDE_DB_PATH=data/hde-live.db
